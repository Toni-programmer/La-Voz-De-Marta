<div class="form-card">
  <%= form_with(model: appointment) do |form| %>
    <% if appointment.errors.any? %>
      <div class="form-errors">
        <strong><%= pluralize(appointment.errors.count, "error") %></strong> impidieron guardar la cita:
        <ul>
          <% appointment.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-group">
      <%= form.label :patient_id, "Paciente" %>
      <%= form.collection_select :patient_id, @patients, :id, :full_name, { include_blank: "Selecciona un paciente..." } %>
    </div>
    <div class="form-group">
      <%= form.label :therapist_id, "Terapeuta" %>
      <%= form.collection_select :therapist_id, @therapists, :id, :name, { include_blank: "Selecciona un terapeuta..." } %>
    </div>
    <div class="form-group">
      <%= form.label :service_id, "Servicio" %>
      <%= form.collection_select :service_id, @services, :id, :name, { include_blank: "Selecciona un servicio..." } %>
    </div>
    <div class="form-group">
      <%= form.label :scheduled_at, "Fecha y hora" %>
      <%= form.datetime_field :scheduled_at %>
    </div>
    <div class="form-group">
      <%= form.label :status, "Estado" %>
      <%= form.select :status, [["Pendiente", "pending"], ["Confirmada", "confirmed"], ["Cancelada", "cancelled"]], { include_blank: "Selecciona..." } %>
    </div>
    <div class="form-group">
      <%= form.label :notes, "Notas" %>
      <%= form.textarea :notes, placeholder: "Observaciones sobre la cita...", rows: 3 %>
    </div>

    <%= form.submit appointment.new_record? ? "Crear cita" : "Guardar cambios", class: "form-btn" %>
  <% end %>
</div>
