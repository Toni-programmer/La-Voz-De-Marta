<div class="form-card">
  <%= form_with(model: testimonial) do |form| %>
    <% if testimonial.errors.any? %>
      <div class="form-errors">
        <strong><%= pluralize(testimonial.errors.count, "error") %></strong> impidieron guardar el testimonio:
        <ul>
          <% testimonial.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-group">
      <%= form.label :author_name, "Nombre" %>
      <%= form.text_field :author_name, placeholder: "Ej: María G." %>
    </div>
    <div class="form-group">
      <%= form.label :role, "Perfil" %>
      <%= form.select :role, ["Madre de paciente", "Padre de paciente", "Paciente adulto", "Familiar de paciente", "Otro"], { include_blank: "Selecciona..." } %>
    </div>
    <div class="form-group">
      <%= form.label :content, "Testimonio" %>
      <%= form.textarea :content, placeholder: "Escribe el testimonio aquí...", rows: 4 %>
    </div>

    <%= form.submit testimonial.new_record? ? "Añadir testimonio" : "Guardar cambios", class: "form-btn" %>
  <% end %>
</div>
