<!DOCTYPE html>
<html lang="es">
  <head>
    <title>La Voz de Marta · Logopedia en Quart de Poblet</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/favicon.ico">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      :root {
        --sand: #F5F0E8;
        --warm-white: #FDFAF5;
        --sage: #7A9E8E;
        --sage-dark: #4A7060;
        --sage-light: #C8DDD5;
        --terracotta: #C4785A;
        --terracotta-light: #EEDDD5;
        --charcoal: #2E2E2E;
        --mid-gray: #6B6B6B;
        --light-border: rgba(46,46,46,0.12);
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        font-family: 'DM Sans', sans-serif;
        background: var(--warm-white);
        color: var(--charcoal);
        line-height: 1.7;
        font-size: 16px;
      }
      nav {
        position: fixed; top: 0; left: 0; right: 0; z-index: 100;
        background: rgba(253,250,245,0.92);
        backdrop-filter: blur(12px);
        border-bottom: 0.5px solid var(--light-border);
        padding: 0 5%;
        display: flex; align-items: center; justify-content: space-between;
        height: 64px;
      }
      .nav-logo {
        font-family: 'Playfair Display', serif;
        font-size: 18px; color: var(--charcoal);
        text-decoration: none;
        display: flex; align-items: center; gap: 10px;
      }
      .nav-logo-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--terracotta); }
      .nav-links { display: flex; gap: 2rem; list-style: none; }
      .nav-links a { text-decoration: none; color: var(--mid-gray); font-size: 14px; font-weight: 400; transition: color .2s; }
      .nav-links a:hover { color: var(--charcoal); }
      .nav-cta { background: var(--sage-dark); color: white !important; padding: 8px 20px; border-radius: 100px; font-size: 14px !important; font-weight: 500 !important; transition: background .2s !important; }
      .nav-cta:hover { background: var(--sage) !important; }
      .hero { min-height: 100vh; display: flex; align-items: center; padding: 100px 5% 60px; position: relative; overflow: hidden; }
      .hero::before { content: ''; position: absolute; top: 0; right: 0; width: 55%; height: 100%; background: var(--sand); clip-path: polygon(12% 0, 100% 0, 100% 100%, 0 100%); z-index: 0; }
      .hero-content { position: relative; z-index: 1; max-width: 580px; }
      .hero-tag { display: inline-flex; align-items: center; gap: 8px; background: var(--terracotta-light); color: var(--terracotta); font-size: 12px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; padding: 6px 14px; border-radius: 100px; margin-bottom: 28px; }
      .hero h1 { font-family: 'Playfair Display', serif; font-size: clamp(2.4rem, 5vw, 3.8rem); font-weight: 600; line-height: 1.15; margin-bottom: 24px; }
      .hero h1 em { font-style: italic; color: var(--sage-dark); }
      .hero-desc { font-size: 17px; color: var(--mid-gray); font-weight: 300; max-width: 460px; margin-bottom: 40px; }
      .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; }
      .btn-primary { background: var(--sage-dark); color: white; padding: 14px 28px; border-radius: 100px; text-decoration: none; font-size: 15px; font-weight: 500; transition: background .2s, transform .15s; display: inline-flex; align-items: center; gap: 8px; }
      .btn-primary:hover { background: var(--sage); transform: translateY(-1px); }
      .btn-secondary { background: transparent; color: var(--charcoal); padding: 14px 28px; border-radius: 100px; border: 1px solid var(--light-border); text-decoration: none; font-size: 15px; font-weight: 400; transition: border-color .2s, background .2s; display: inline-flex; align-items: center; gap: 8px; }
      .btn-secondary:hover { border-color: var(--sage); background: rgba(122,158,142,.06); }
      .hero-stats { display: flex; gap: 32px; margin-top: 56px; padding-top: 32px; border-top: 0.5px solid var(--light-border); }
      .stat-num { font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 600; }
      .stat-label { font-size: 13px; color: var(--mid-gray); margin-top: 2px; }
      section { padding: 90px 5%; }
      .section-tag { display: inline-block; font-size: 11px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--terracotta); margin-bottom: 16px; }
      .section-title { font-family: 'Playfair Display', serif; font-size: clamp(1.8rem, 3vw, 2.6rem); font-weight: 600; line-height: 1.2; margin-bottom: 16px; }
      .section-desc { color: var(--mid-gray); font-weight: 300; max-width: 520px; margin-bottom: 56px; }
      .about { background: var(--sand); }
      .about-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 60px; align-items: center; max-width: 1100px; margin: 0 auto; }
      .about-card { background: var(--warm-white); border-radius: 24px; padding: 48px 40px; border: 0.5px solid var(--light-border); position: relative; }
      .about-card-deco { position: absolute; top: -20px; left: 32px; background: var(--terracotta); width: 40px; height: 40px; border-radius: 12px; display: flex; align-items: center; justify-content: center; }
      .about-card-deco svg { width: 22px; height: 22px; fill: white; }
      .about-name { font-family: 'Playfair Display', serif; font-size: 26px; margin-bottom: 6px; }
      .about-title { color: var(--sage-dark); font-size: 14px; font-weight: 500; margin-bottom: 24px; }
      .about-credentials { list-style: none; }
      .about-credentials li { padding: 10px 0; border-bottom: 0.5px solid var(--light-border); font-size: 14px; color: var(--mid-gray); display: flex; align-items: flex-start; gap: 10px; }
      .about-credentials li::before { content: '·'; color: var(--sage-dark); font-size: 20px; line-height: 1; flex-shrink: 0; }
      .about-text p { color: var(--mid-gray); font-weight: 300; margin-bottom: 18px; font-size: 16px; }
      .highlight-pill { display: inline-flex; gap: 8px; flex-wrap: wrap; margin-top: 20px; }
      .pill { background: var(--sage-light); color: var(--sage-dark); font-size: 13px; font-weight: 500; padding: 6px 14px; border-radius: 100px; }
      .services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; max-width: 1100px; margin: 0 auto; }
      .service-card { background: var(--warm-white); border: 0.5px solid var(--light-border); border-radius: 20px; padding: 32px 28px; transition: border-color .2s, transform .2s; position: relative; overflow: hidden; }
      .service-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--sage-dark); opacity: 0; transition: opacity .2s; }
      .service-card:hover { border-color: var(--sage-light); transform: translateY(-3px); }
      .service-card:hover::before { opacity: 1; }
      .service-icon { width: 48px; height: 48px; background: var(--terracotta-light); border-radius: 14px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px; }
      .service-icon svg { width: 24px; height: 24px; stroke: var(--terracotta); fill: none; stroke-width: 1.5; }
      .service-name { font-family: 'Playfair Display', serif; font-size: 19px; font-weight: 600; margin-bottom: 10px; }
      .service-desc { font-size: 14px; color: var(--mid-gray); font-weight: 300; line-height: 1.6; }
      .service-tags { margin-top: 16px; display: flex; gap: 6px; flex-wrap: wrap; }
      .service-tag { background: var(--sand); color: var(--mid-gray); font-size: 11px; font-weight: 500; padding: 4px 10px; border-radius: 100px; }
      .process { background: var(--charcoal); color: white; }
      .process .section-title { color: white; }
      .process .section-desc { color: rgba(255,255,255,0.6); }
      .process-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: rgba(255,255,255,0.08); border-radius: 16px; overflow: hidden; max-width: 1100px; margin: 0 auto; }
      .process-step { background: var(--charcoal); padding: 40px 28px; }
      .step-num { font-family: 'Playfair Display', serif; font-size: 42px; font-weight: 600; color: rgba(255,255,255,0.15); margin-bottom: 16px; line-height: 1; }
      .step-name { font-weight: 500; font-size: 16px; color: white; margin-bottom: 10px; }
      .step-desc { font-size: 14px; color: rgba(255,255,255,0.55); font-weight: 300; }
      .modalities-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; max-width: 1100px; margin: 0 auto; }
      .modality-card { border-radius: 20px; padding: 40px 36px; position: relative; overflow: hidden; }
      .modality-card.presencial { background: var(--sage-light); }
      .modality-card.online { background: var(--terracotta-light); }
      .modality-num { font-family: 'Playfair Display', serif; font-size: 72px; font-weight: 600; position: absolute; top: 20px; right: 28px; opacity: 0.15; line-height: 1; }
      .presencial .modality-num { color: var(--sage-dark); }
      .online .modality-num { color: var(--terracotta); }
      .modality-badge { font-size: 11px; font-weight: 500; letter-spacing: .1em; text-transform: uppercase; margin-bottom: 14px; }
      .presencial .modality-badge { color: var(--sage-dark); }
      .online .modality-badge { color: var(--terracotta); }
      .modality-title { font-family: 'Playfair Display', serif; font-size: 26px; font-weight: 600; margin-bottom: 14px; color: var(--charcoal); }
      .modality-desc { font-size: 15px; color: var(--mid-gray); font-weight: 300; }
      .contact { background: var(--sand); }
      .contact-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 80px; align-items: start; max-width: 1100px; margin: 0 auto; }
      .contact-info-item { display: flex; align-items: flex-start; gap: 16px; margin-bottom: 32px; }
      .contact-icon { width: 44px; height: 44px; border-radius: 12px; background: white; display: flex; align-items: center; justify-content: center; flex-shrink: 0; border: 0.5px solid var(--light-border); }
      .contact-icon svg { width: 20px; height: 20px; stroke: var(--sage-dark); fill: none; stroke-width: 1.5; }
      .contact-label { font-size: 12px; color: var(--mid-gray); font-weight: 500; margin-bottom: 4px; }
      .contact-value { font-size: 15px; color: var(--charcoal); }
      .contact-value a { color: var(--sage-dark); text-decoration: none; }
      .contact-form-card { background: white; border-radius: 20px; padding: 36px; border: 0.5px solid var(--light-border); }
      .form-title { font-family: 'Playfair Display', serif; font-size: 22px; margin-bottom: 24px; }
      .form-group { margin-bottom: 18px; }
      .form-group label { display: block; font-size: 13px; color: var(--mid-gray); margin-bottom: 6px; font-weight: 500; }
      .form-group input, .form-group textarea, .form-group select { width: 100%; border: 0.5px solid var(--light-border); border-radius: 10px; padding: 12px 14px; font-family: 'DM Sans', sans-serif; font-size: 14px; color: var(--charcoal); background: var(--warm-white); outline: none; transition: border-color .2s; appearance: none; }
      .form-group input:focus, .form-group textarea:focus, .form-group select:focus { border-color: var(--sage); }
      .form-group textarea { resize: vertical; min-height: 100px; }
      .form-btn { width: 100%; padding: 14px; background: var(--sage-dark); color: white; border: none; border-radius: 100px; font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 500; cursor: pointer; transition: background .2s; }
      .form-btn:hover { background: var(--sage); }
      .hours-grid { display: flex; flex-direction: column; gap: 8px; margin-top: 28px; }
      .hour-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 16px; border-radius: 10px; background: white; border: 0.5px solid var(--light-border); font-size: 14px; }
      .hour-day { color: var(--mid-gray); }
      .hour-time { font-weight: 500; }
      .hour-closed { color: var(--mid-gray); }
      footer { background: var(--charcoal); color: rgba(255,255,255,0.7); padding: 48px 5%; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 20px; }
      .footer-logo { font-family: 'Playfair Display', serif; font-size: 20px; color: white; }
      .footer-links { display: flex; gap: 24px; list-style: none; }
      .footer-links a { color: rgba(255,255,255,0.5); text-decoration: none; font-size: 13px; transition: color .2s; }
      .footer-links a:hover { color: white; }
      .footer-copy { font-size: 12px; }
      .wa-float { position: fixed; bottom: 28px; right: 28px; z-index: 200; width: 56px; height: 56px; border-radius: 50%; background: #25D366; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 16px rgba(37,211,102,.4); text-decoration: none; transition: transform .2s; }
      .wa-float:hover { transform: scale(1.08); }
      .wa-float svg { width: 28px; height: 28px; fill: white; }
      .nav-active { color: var(--charcoal) !important; font-weight: 500 !important; }
      /* === Inner pages === */
      .page-wrapper { max-width: 1100px; margin: 0 auto; padding: 88px 5% 60px; }
      .page-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 32px; flex-wrap: wrap; gap: 16px; }
      .page-title { font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 600; line-height: 1.2; }
      .page-subtitle { color: var(--mid-gray); font-size: 14px; margin-top: 4px; }
      .flash-notice { background: var(--sage-light); color: var(--sage-dark); padding: 12px 18px; border-radius: 10px; font-size: 14px; margin-bottom: 24px; }
      .flash-alert { background: var(--terracotta-light); color: var(--terracotta); padding: 12px 18px; border-radius: 10px; font-size: 14px; margin-bottom: 24px; }
      .data-table { width: 100%; border-collapse: collapse; background: white; border-radius: 16px; overflow: hidden; border: 0.5px solid var(--light-border); }
      .data-table th { text-align: left; padding: 12px 20px; font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.08em; color: var(--mid-gray); background: var(--sand); border-bottom: 0.5px solid var(--light-border); }
      .data-table td { padding: 14px 20px; font-size: 14px; border-bottom: 0.5px solid var(--light-border); vertical-align: middle; }
      .data-table tr:last-child td { border-bottom: none; }
      .data-table tr:hover td { background: var(--warm-white); }
      .data-table .actions { text-align: right; white-space: nowrap; }
      .table-empty { text-align: center; padding: 60px 20px; color: var(--mid-gray); font-size: 15px; }
      .detail-card { background: white; border-radius: 20px; border: 0.5px solid var(--light-border); padding: 36px; max-width: 700px; }
      .detail-row { display: grid; grid-template-columns: 180px 1fr; gap: 12px; padding: 14px 0; border-bottom: 0.5px solid var(--light-border); align-items: start; }
      .detail-row:last-child { border-bottom: none; }
      .detail-label { font-size: 12px; color: var(--mid-gray); font-weight: 500; text-transform: uppercase; letter-spacing: 0.06em; padding-top: 2px; }
      .detail-value { font-size: 15px; color: var(--charcoal); }
      .form-card { background: white; border-radius: 20px; border: 0.5px solid var(--light-border); padding: 36px; max-width: 600px; }
      .form-errors { background: var(--terracotta-light); color: var(--terracotta); border-radius: 10px; padding: 14px 18px; margin-bottom: 20px; font-size: 14px; }
      .form-errors ul { margin: 8px 0 0 16px; }
      .btn-sm { display: inline-flex; align-items: center; gap: 6px; padding: 7px 16px; border-radius: 100px; font-size: 13px; font-weight: 500; text-decoration: none; transition: background .2s, border-color .2s; cursor: pointer; border: none; font-family: 'DM Sans', sans-serif; }
      .btn-sm-primary { background: var(--sage-dark); color: white; }
      .btn-sm-primary:hover { background: var(--sage); color: white; }
      .btn-sm-secondary { background: transparent; color: var(--charcoal); border: 0.5px solid var(--light-border); }
      .btn-sm-secondary:hover { border-color: var(--sage); background: rgba(122,158,142,.06); }
      .btn-sm-danger { background: transparent; color: #c0392b; border: 0.5px solid rgba(192,57,43,.2); }
      .btn-sm-danger:hover { background: rgba(192,57,43,.06); }
      .action-bar { display: flex; gap: 10px; margin-top: 24px; flex-wrap: wrap; align-items: center; }
      .status-badge { display: inline-flex; align-items: center; padding: 4px 12px; border-radius: 100px; font-size: 12px; font-weight: 500; }
      .status-pending, .status-unpaid { background: #FFF3CD; color: #856404; }
      .status-confirmed, .status-paid { background: var(--sage-light); color: var(--sage-dark); }
      .status-cancelled { background: var(--terracotta-light); color: var(--terracotta); }
      /* === Foto placeholder === */
      .about-photo { width: 100%; aspect-ratio: 3/4; background: var(--sage-light); border-radius: 24px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
      .about-photo-initials { font-family: 'Playfair Display', serif; font-size: 72px; color: var(--sage-dark); opacity: 0.4; }
      .about-photo img { width: 100%; height: 100%; object-fit: cover; }
      /* === Testimonios === */
      .testimonials { background: var(--sand); }
      .testimonials-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; max-width: 1100px; margin: 0 auto; }
      .testimonial-card { background: white; border-radius: 20px; padding: 32px 28px; border: 0.5px solid var(--light-border); }
      .testimonial-quote { font-size: 32px; color: var(--terracotta); line-height: 1; margin-bottom: 12px; font-family: 'Playfair Display', serif; }
      .testimonial-text { font-size: 15px; color: var(--mid-gray); font-weight: 300; line-height: 1.7; margin-bottom: 20px; }
      .testimonial-author { font-weight: 500; font-size: 14px; color: var(--charcoal); }
      .testimonial-role { font-size: 12px; color: var(--mid-gray); margin-top: 2px; }
      /* === Blog === */
      .blog-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; max-width: 1100px; margin: 0 auto; }
      .blog-card { background: white; border-radius: 20px; border: 0.5px solid var(--light-border); padding: 32px 28px; transition: transform .2s, border-color .2s; text-decoration: none; color: inherit; display: block; }
      .blog-card:hover { transform: translateY(-3px); border-color: var(--sage-light); }
      .blog-date { font-size: 12px; color: var(--mid-gray); font-weight: 500; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 12px; }
      .blog-title { font-family: 'Playfair Display', serif; font-size: 19px; font-weight: 600; margin-bottom: 10px; line-height: 1.3; }
      .blog-excerpt { font-size: 14px; color: var(--mid-gray); font-weight: 300; line-height: 1.6; }
      .blog-empty { color: var(--mid-gray); font-size: 15px; font-weight: 300; }
      @media (max-width: 768px) {
        /* Nav */
        nav .nav-links { display: none; }

        /* Hero */
        .hero { padding: 88px 5% 48px; min-height: auto; }
        .hero::before { width: 100%; clip-path: none; opacity: .35; }
        .hero-stats { flex-wrap: wrap; gap: 16px; margin-top: 36px; padding-top: 24px; }

        /* General */
        section { padding: 60px 5%; }
        .section-desc { max-width: 100%; margin-bottom: 32px; }

        /* About */
        .about-grid { grid-template-columns: 1fr; gap: 28px; }
        .about-photo { aspect-ratio: 3/2; max-height: 220px; }
        .about-card { padding: 28px 20px; }

        /* Services */
        .services-grid { grid-template-columns: 1fr; }
        .service-card { padding: 24px 20px; }

        /* Process */
        .process-steps { grid-template-columns: 1fr; }
        .process-step { padding: 28px 24px; }
        .step-num { font-size: 32px; margin-bottom: 10px; }

        /* Modalidades */
        .modalities-grid { grid-template-columns: 1fr; gap: 16px; }
        .modality-card { padding: 28px 24px; }
        .modality-num { font-size: 52px; }

        /* Testimonios */
        .testimonials-grid { grid-template-columns: 1fr; }
        .testimonial-card { padding: 24px 20px; }

        /* Blog */
        .blog-grid { grid-template-columns: 1fr; }

        /* Contacto */
        .contact-grid { grid-template-columns: 1fr; gap: 36px; }
        .contact-form-card { padding: 24px 20px; }

        /* Footer */
        footer { flex-direction: column; align-items: center; text-align: center; gap: 16px; padding: 36px 5% 100px; }
        .footer-links { justify-content: center; flex-wrap: wrap; gap: 16px; }
      }
    </style>
  </head>
  <body>
    <nav>
      <a href="<%= root_path %>" class="nav-logo">
        <span class="nav-logo-dot"></span>
        La Voz de Marta
      </a>
      <ul class="nav-links">
        <li><a href="<%= root_path %>#servicios">Servicios</a></li>
        <li><a href="<%= root_path %>#sobre-mi">Sobre mí</a></li>
        <li><a href="<%= root_path %>#proceso">Cómo funciona</a></li>
        <li><a href="<%= posts_path %>">Blog</a></li>
        <li><a href="<%= testimonials_path %>">Testimonios</a></li>
        <li><a href="<%= root_path %>#contacto" class="nav-cta">Pedir cita</a></li>
      </ul>
    </nav>
    <%= yield %>
  </body>
</html>
