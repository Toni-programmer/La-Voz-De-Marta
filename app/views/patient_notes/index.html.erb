<% content_for :title, "Notas de sesión" %>

<div class="page-wrapper">
  <div class="page-header">
    <div>
      <h1 class="page-title">Notas de sesión</h1>
      <p class="page-subtitle">Registro clínico por paciente</p>
    </div>
    <%= link_to "Nueva nota", new_patient_note_path, class: "btn-primary" %>
  </div>

  <% if notice.present? %>
    <div class="flash-notice"><%= notice %></div>
  <% end %>

  <% if @patient_notes.any? %>
    <table class="data-table">
      <thead>
        <tr>
          <th>Paciente</th>
          <th>Fecha de sesión</th>
          <th>Contenido</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @patient_notes.each do |note| %>
          <tr>
            <td><strong><%= note.patient.full_name %></strong></td>
            <td><%= note.session_date&.strftime("%d/%m/%Y") %></td>
            <td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= note.content %></td>
            <td class="actions">
              <%= link_to "Ver", note, class: "btn-sm btn-sm-primary" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="table-empty">No hay notas todavía. <%= link_to "Añade la primera", new_patient_note_path %>.</div>
  <% end %>
</div>
