<div class="detail-card" id="<%= dom_id patient_note %>">
  <div class="detail-row">
    <span class="detail-label">Paciente</span>
    <span class="detail-value"><%= link_to patient_note.patient.full_name, patient_note.patient, style: "color: var(--sage-dark)" %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">Fecha de sesión</span>
    <span class="detail-value"><%= patient_note.session_date&.strftime("%d/%m/%Y") || "—" %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">Contenido</span>
    <span class="detail-value" style="white-space:pre-wrap"><%= patient_note.content %></span>
  </div>
</div>
