<% content_for :title, @patient.full_name %>

<div class="page-wrapper">
  <div class="page-header">
    <div>
      <h1 class="page-title"><%= @patient.full_name %></h1>
      <p class="page-subtitle">Ficha del paciente</p>
    </div>
    <div style="display:flex;gap:10px">
      <%= link_to "Editar", edit_patient_path(@patient), class: "btn-sm btn-sm-secondary" %>
      <%= button_to "Eliminar", @patient, method: :delete, class: "btn-sm btn-sm-danger", data: { turbo_confirm: "¿Seguro que quieres eliminar este paciente?" } %>
    </div>
  </div>

  <% if notice.present? %>
    <div class="flash-notice"><%= notice %></div>
  <% end %>

  <%= render @patient %>

  <div class="action-bar">
    <%= link_to "← Volver a pacientes", patients_path, class: "btn-sm btn-sm-secondary" %>
  </div>
</div>
