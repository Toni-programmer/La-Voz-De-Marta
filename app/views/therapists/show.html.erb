<% content_for :title, @therapist.name %>

<div class="page-wrapper">
  <div class="page-header">
    <div>
      <h1 class="page-title"><%= @therapist.name %></h1>
      <p class="page-subtitle">Ficha del terapeuta</p>
    </div>
    <div style="display:flex;gap:10px">
      <%= link_to "Editar", edit_therapist_path(@therapist), class: "btn-sm btn-sm-secondary" %>
      <%= button_to "Eliminar", @therapist, method: :delete, class: "btn-sm btn-sm-danger", data: { turbo_confirm: "¿Seguro que quieres eliminar este terapeuta?" } %>
    </div>
  </div>

  <% if notice.present? %>
    <div class="flash-notice"><%= notice %></div>
  <% end %>

  <%= render @therapist %>

  <div class="action-bar">
    <%= link_to "← Volver a terapeutas", therapists_path, class: "btn-sm btn-sm-secondary" %>
  </div>
</div>
