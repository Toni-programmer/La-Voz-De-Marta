<div class="form-card">
  <%= form_with(model: therapist) do |form| %>
    <% if therapist.errors.any? %>
      <div class="form-errors">
        <strong><%= pluralize(therapist.errors.count, "error") %></strong> impidieron guardar el terapeuta:
        <ul>
          <% therapist.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-group">
      <%= form.label :name, "Nombre" %>
      <%= form.text_field :name, placeholder: "Nombre completo" %>
    </div>
    <div class="form-group">
      <%= form.label :email, "Email" %>
      <%= form.text_field :email, placeholder: "correo@ejemplo.com" %>
    </div>
    <div class="form-group">
      <%= form.label :college_number, "Nº de colegiado" %>
      <%= form.text_field :college_number, placeholder: "Ej: 461249" %>
    </div>

    <%= form.submit therapist.new_record? ? "Crear terapeuta" : "Guardar cambios", class: "form-btn" %>
  <% end %>
</div>
